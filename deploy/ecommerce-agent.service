[Unit]
Description=Agente IA Ecommerce - FastAPI
After=network.target

[Service]
# Ajusta el usuario y las rutas según tu instancia OCI
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ecommerce-agent
EnvironmentFile=/home/ubuntu/ecommerce-agent/.env
ExecStart=/home/ubuntu/ecommerce-agent/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
