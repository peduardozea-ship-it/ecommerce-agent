# Copia este archivo a ".env" y completa tus valores reales.
# IMPORTANTE: nunca subas el archivo ".env" real a GitHub.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# Carpeta donde están los documentos fuente de la tienda (PDF, DOCX, TXT, MD)
DOCS_PATH=./data

# Carpeta donde ChromaDB persiste el índice vectorial
CHROMA_PERSIST_DIR=./chroma_db

# Nombre de la colección dentro de ChromaDB
CHROMA_COLLECTION_NAME=ecommerce_kb

# Modelo de embeddings local (HuggingFace, se descarga una sola vez)
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Nombre de tu tienda ficticia, usado en el prompt del agente
STORE_NAME=TiendaEjemplo

# Host/puerto de la API
API_HOST=0.0.0.0
API_PORT=8000
